T(n) = 
{
1                 se n < 2
T(n-1)+T(n-2)+1   se n>=2
}

T(n) =  T(n-1)+T(n-2)+1
     >= 2T(n-2)+1

T(n)   >= 2T(n-2)+1
       >= 4T(n-4)+2+1
       >= 8T(n-8)+4+2+1
       >= 2^(k)T(n-2k)+2^(k-1)+2^(k-2)+...*2^0
        = 2^(k)T(n-2k)+sum_(i=0)^(k-1) 2^i
        = 2^(k)T(n-2k)+2^k -1
        = 2*2^(n/2)-1
        = 2^(n/2)
        = sqrt(2)^n


2T(n-2)+1 >= 2(2T(n-4)+1)+1 
           = 4T(n-4)+3
          >= 8T(n-6)+7



