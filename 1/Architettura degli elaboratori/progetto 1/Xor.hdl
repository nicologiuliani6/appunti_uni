// File name: projects/01/Xor.hdl

/**
 * Exclusive-or gate:
 * out = not (a == b)
 */

CHIP Xor {
    IN a, b;
    OUT out;

    PARTS:
    Not(in=a,out=a-neg);
    And(a=a-neg,b=b,out=temp1);
    Not(in=b,out=b-neg);
    And(a=a,b=b-neg,out=temp2);
    Or(a=temp1,b=temp2,out=out);
}