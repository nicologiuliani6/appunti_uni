// Funzione "multiplyNumbers" che simula la moltiplicazione
function multiplyNumbers 2
push argument 0           // Pusha il primo argomento
push argument 1           // Pusha il secondo argomento
push constant 0          // Pusha 0 come somma iniziale
label MULTIPLY_LOOP
push argument 1           // Pusha il secondo argomento
push constant 1           // Pusha 1
sub                       // Decrementa il secondo argomento
pop argument 1            // Salva il risultato in argument[1]
push argument 0           // Pusha il primo argomento
push constant 1           // Pusha 1
add                       // Somma il primo argomento
pop argument 0            // Salva il risultato in argument[0]
push argument 1           // Pusha il secondo argomento
push constant 0          // Pusha 0
eq                        // Controlla se il secondo argomento è 0
if-goto MULTIPLY_END      // Se è 0, esce dal ciclo
goto MULTIPLY_LOOP        // Ripete il ciclo
label MULTIPLY_END
return                   // Restituisce il risultato (prodotto)

// Funzione che esegue un ciclo di somma
function sumLoop 1        // Funzione che usa 1 variabile locale
push argument 0           // Pusha l'argomento
push constant 0          // Pusha 0 (somma iniziale)
label SUM_LOOP
push local 0             // Pusha local[0]
push constant 100        // Pusha 100
lt                        // Verifica se local[0] < 100
if-goto SUM_END          // Esce se la condizione non è più soddisfatta
push local 0             // Pusha local[0]
push constant 1          // Pusha 1
add                       // Aumenta local[0] di 1
pop local 0               // Salva il nuovo valore in local[0]
push constant 1          // Pusha 1
add                       // Incrementa la somma
pop local 0               // Salva la somma in local[0]
goto SUM_LOOP             // Ripete il ciclo
label SUM_END

// Funzione di test che calcola il quadrato di un numero
function squareNumber 1
push argument 0           // Pusha l'argomento
push argument 0           // Pusha l'argomento di nuovo
add                       // Somma il numero a sé stesso
return                   // Restituisce il risultato (quadrato)

// Funzione per incrementare valori
function incrementBy 2    // Funzione con 2 parametri
push argument 0           // Pusha il primo argomento
push argument 1           // Pusha il secondo argomento
add                       // Somma i due argomenti
return                   // Restituisce il risultato

// Funzione per decrementare valori
function decrementBy 2    // Funzione con 2 parametri
push argument 0           // Pusha il primo argomento
push argument 1           // Pusha il secondo argomento
sub                       // Sottrae il secondo argomento dal primo
return                   // Restituisce il risultato

